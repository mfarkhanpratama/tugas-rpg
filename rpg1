        class Novice
        {
            public string Name { get; set; }

            public int attackPower { get; set; }

            public int health { get; set; }
            public int energy { get; set; }
            public float exp { get; set; }
            public bool isdead { get; set; }
            Random rnd = new Random();

            public Novice()
            {
                health = 100;
                energy = 0;
                attackPower = 1;
                isdead = false;
                exp = 0f;
                Name = "newbie";
            }

            public virtual void BasicAttack()
            {
                attackPower = 1;
            }
            public virtual void SpecialSkill()
            {
                if (energy > 0)
                {
                    Console.WriteLine("SWINGGG ATTACKK!!!");
                    attackPower = 1;
                    attackPower += rnd.Next(3, 11);
                    energy--;
                }
                else
                {
                    Console.WriteLine(" your energy isnt enough to cast special skill ");
                }
            }
            public void rest()
            {
                energy++;
                attackPower = 1;
            }

            public void gethit(int hitvalue)
            {
                Console.WriteLine(Name + " get hit by " + hitvalue);
                health -= hitvalue;

            }

            private void die()
            {
                Console.WriteLine(Name + " is dead , game over ");
                isdead = true;
            }
        }

